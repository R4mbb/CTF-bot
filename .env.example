# Discord Bot Token (required)
DISCORD_TOKEN=
# Discord Bot Application ID (required)
DISCORD_APP_ID=

# Guild ID for development (optional, speeds up slash command sync)
DEV_GUILD_ID=

# Database URL (default: sqlite+aiosqlite:///./data/ctfbot.db)
DATABASE_URL=sqlite+aiosqlite:///./data/ctfbot.db

# Admin role name (users with this role OR Manage Guild permission are admins)
ADMIN_ROLE_NAME=CTF Admin

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Timezone for display (internal times are always UTC)
TIMEZONE=UTC

# CTFTime cache TTL in seconds (default: 1800 = 30 minutes)
CTFTIME_CACHE_TTL=1800

# Scheduler check interval in minutes
SCHEDULER_INTERVAL_MINUTES=5

# Channel name for weekly CTFTime digest
ANNOUNCEMENT_CHANNEL=ctf-일정
